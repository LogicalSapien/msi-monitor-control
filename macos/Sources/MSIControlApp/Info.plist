<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hide the Dock icon — this is a menu-bar-only app. -->
    <key>LSUIElement</key>
    <true/>
    <key>CFBundleName</key>
    <string>MSI Monitor Control</string>
    <key>CFBundleDisplayName</key>
    <string>MSI Monitor Control</string>
    <key>CFBundleIdentifier</key>
    <string>com.logicalsapien.msimonitorcontrol</string>
    <key>CFBundleExecutable</key>
    <string>MSIControlApp</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <!-- Icon: build-app.sh copies assets/icon.icns into Contents/Resources/icon.icns.
         CFBundleIconFile is the file name (extension optional); CFBundleIconName
         lets a future asset catalogue resolve the same icon. Until the asset is
         committed the app falls back to the default icon. -->
    <key>CFBundleIconFile</key>
    <string>icon.icns</string>
    <key>CFBundleIconName</key>
    <string>icon</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
</dict>
</plist>
